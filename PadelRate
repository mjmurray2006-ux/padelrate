<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PadelRate — Best Padel Racket Reviews & Ratings UK 2026</title>
<meta name="description" content="Independent padel racket reviews and ratings for every level. Compare power, control and touch scores, filter by budget, and find the best padel racket for you.">
<meta name="keywords" content="padel racket reviews, best padel racket UK, padel racket ratings, padel equipment">
<meta property="og:title" content="PadelRate — Best Padel Racket Reviews UK 2026">
<meta property="og:description" content="Honest, data-driven padel racket ratings. Filter by level, shape and price.">
<meta property="og:type" content="website">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0e0e0e;--surface:#161616;--surface2:#1e1e1e;--border:#2a2a2a;--accent:#c8f135;--accent-dim:#a8d020;--text:#f0f0f0;--muted:#888;--tag-bg:#252525}
body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;min-height:100vh}
nav{display:flex;align-items:center;justify-content:space-between;padding:18px 40px;border-bottom:1px solid var(--border);position:sticky;top:0;background:rgba(14,14,14,0.95);backdrop-filter:blur(8px);z-index:100}
.logo{font-size:1.4rem;font-weight:800;letter-spacing:-0.5px;text-decoration:none;color:var(--text)}
.logo span{color:var(--accent)}
.nav-links{display:flex;gap:28px;font-size:0.88rem}
.nav-links a{color:var(--muted);text-decoration:none;transition:color 0.2s}
.nav-links a:hover{color:var(--text)}
.hero{padding:64px 40px 40px;max-width:900px}
.hero-tag{display:inline-block;background:var(--accent);color:#000;font-size:0.72rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:4px 10px;border-radius:3px;margin-bottom:18px}
.hero h1{font-size:3rem;font-weight:800;line-height:1.1;letter-spacing:-1px;margin-bottom:16px}
.hero h1 span{color:var(--accent)}
.hero p{font-size:1.05rem;color:var(--muted);max-width:560px;line-height:1.6}
.best-for{padding:32px 40px 40px}
.section-title{font-size:1.3rem;font-weight:800;margin-bottom:20px;letter-spacing:-0.3px}
.section-title span{color:var(--accent)}
.best-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px}
.best-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:18px;text-decoration:none;color:var(--text);transition:border-color 0.2s,transform 0.2s;display:flex;flex-direction:column;gap:6px}
.best-card:hover{border-color:var(--accent);transform:translateY(-2px)}
.best-label{font-size:0.7rem;color:var(--accent);font-weight:700;text-transform:uppercase;letter-spacing:1px}
.best-name{font-size:0.92rem;font-weight:700}
.best-brand{font-size:0.75rem;color:var(--muted)}
.best-score{font-size:1.5rem;font-weight:800;color:var(--accent);margin-top:4px}
.divider{margin:0 40px 40px;border:none;border-top:1px solid var(--border)}
.filters-bar{padding:0 40px 32px;display:flex;flex-wrap:wrap;gap:12px;align-items:center}
.filter-group{display:flex;align-items:center;gap:8px}
.filter-group label{font-size:0.78rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.8px;white-space:nowrap}
select{background:var(--surface2);border:1px solid var(--border);color:var(--text);padding:7px 12px;border-radius:6px;font-size:0.85rem;cursor:pointer;outline:none;transition:border-color 0.2s}
select:hover,select:focus{border-color:var(--accent)}
.sort-group{margin-left:auto}
.stats-bar{padding:0 40px 20px;display:flex;gap:28px;font-size:0.8rem;color:var(--muted)}
.stats-bar strong{color:var(--text)}
.grid{padding:0 40px 60px;display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:transform 0.2s,border-color 0.2s;display:flex;flex-direction:column;text-decoration:none;color:var(--text)}
.card:hover{transform:translateY(-3px);border-color:#3a3a3a}
.card-img{background:var(--surface2);height:200px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.card-img img{height:180px;width:100%;object-fit:contain;padding:16px;transition:transform 0.3s}
.card:hover .card-img img{transform:scale(1.05)}
.img-fallback{opacity:0.2}
.card-badge{position:absolute;top:12px;right:12px;background:var(--accent);color:#000;font-size:0.7rem;font-weight:700;padding:3px 8px;border-radius:4px;text-transform:uppercase;letter-spacing:0.8px}
.card-badge.editors{background:#ff6b35;color:#fff}
.card-badge.budget{background:#3ecfff;color:#000}
.card-body{padding:18px 20px;flex:1;display:flex;flex-direction:column;gap:12px}
.card-top{display:flex;justify-content:space-between;align-items:flex-start}
.card-title{font-size:1rem;font-weight:700;line-height:1.3}
.card-brand{font-size:0.78rem;color:var(--muted);margin-top:2px}
.score{flex-shrink:0;background:var(--accent);color:#000;font-size:1.3rem;font-weight:800;width:48px;height:48px;border-radius:8px;display:flex;align-items:center;justify-content:center}
.tags{display:flex;flex-wrap:wrap;gap:6px}
.tag{background:var(--tag-bg);border:1px solid var(--border);font-size:0.72rem;color:var(--muted);padding:3px 9px;border-radius:20px}
.stat-bars{display:flex;flex-direction:column;gap:8px}
.stat-row{display:flex;align-items:center;gap:10px}
.stat-label{font-size:0.72rem;color:var(--muted);width:52px;text-transform:uppercase;letter-spacing:0.5px;flex-shrink:0}
.stat-track{flex:1;height:5px;background:var(--border);border-radius:99px;overflow:hidden}
.stat-fill{height:100%;background:var(--accent);border-radius:99px}
.stat-val{font-size:0.72rem;color:var(--muted);width:24px;text-align:right}
.card-bottom{display:flex;justify-content:space-between;align-items:center;margin-top:auto;padding-top:4px}
.price{font-size:1.15rem;font-weight:700}
.price .orig{font-size:0.78rem;color:var(--muted);text-decoration:line-through;font-weight:400;margin-left:6px}
.btn{background:var(--accent);color:#000;border:none;padding:8px 16px;border-radius:6px;font-size:0.82rem;font-weight:700;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:5px;transition:background 0.2s}
.btn:hover{background:var(--accent-dim)}
.no-results{grid-column:1/-1;text-align:center;padding:60px 0;color:var(--muted)}
footer{border-top:1px solid var(--border);padding:28px 40px;display:flex;justify-content:space-between;align-items:center;font-size:0.8rem;color:var(--muted)}
footer a{color:var(--muted);text-decoration:none}
footer a:hover{color:var(--text)}
@media(max-width:600px){nav,.hero,.filters-bar,.grid,footer,.stats-bar,.best-for{padding-left:18px;padding-right:18px}.hero h1{font-size:2rem}.sort-group{margin-left:0}}
</style>
</head>
<body>

<nav>
  <a class="logo" href="index.html">Padel<span>Rate</span></a>
  <div class="nav-links">
    <a href="index.html">Rackets</a>
    <a href="#best-for">Best For</a>
    <a href="about.html">About</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-tag">Independent Reviews</div>
  <h1>Find Your Perfect<br><span>Padel Racket</span></h1>
  <p>Honest, data-driven ratings for every level. Filter, compare, and click through to the best prices online.</p>
</div>

<div class="best-for" id="best-for">
  <div class="section-title">Best <span>Picks</span> by Category</div>
  <div class="best-grid" id="bestGrid"></div>
</div>

<hr class="divider">

<div class="filters-bar">
  <div class="filter-group"><label>Level</label><select id="filterLevel"><option value="all">All Levels</option><option value="beginner">Beginner</option><option value="intermediate">Intermediate</option><option value="advanced">Advanced</option></select></div>
  <div class="filter-group"><label>Shape</label><select id="filterShape"><option value="all">All Shapes</option><option value="round">Round</option><option value="teardrop">Teardrop</option><option value="diamond">Diamond</option></select></div>
  <div class="filter-group"><label>Max Price</label><select id="filterPrice"><option value="999">Any Price</option><option value="100">Under £100</option><option value="150">Under £150</option><option value="200">Under £200</option><option value="300">Under £300</option><option value="400">Under £400</option></select></div>
  <div class="filter-group sort-group"><label>Sort</label><select id="sortBy"><option value="score">Top Rated</option><option value="price_asc">Price: Low–High</option><option value="price_desc">Price: High–Low</option><option value="power">Most Power</option><option value="control">Most Control</option></select></div>
</div>

<div class="stats-bar">
  <span id="countLabel"><strong>7</strong> rackets found</span>
  <span>Last updated: <strong>April 2026</strong></span>
</div>

<div class="grid" id="racketGrid"></div>

<footer>
  <span>© 2026 <a href="index.html">PadelRate</a> — Independent affiliate reviews</span>
  <span>Affiliate links help support this site at no extra cost · <a href="about.html">About Us</a></span>
</footer>

<script>
var rackets = [
  {slug:"bullpadel-hack-03-hybrid",name:"Hack 03 Hybrid",brand:"Bullpadel",level:"advanced",shape:"diamond",price:249,origPrice:279,score:94,power:92,control:80,touch:75,badge:"editors",badgeText:"Editor's Pick",tags:["Power","Diamond","Carbon Fibre"],img:"https://cdn-mdb.head.com/CDN3/G/221075/1/683x911/speed-motion-2025.webp"},
  {slug:"head-speed-motion",name:"Speed Motion",brand:"Head",level:"beginner",shape:"round",price:89,score:85,power:72,control:88,touch:90,badge:"budget",badgeText:"Best Value",tags:["Beginner","Control","Round"],img:"https://cdn-mdb.head.com/CDN3/G/221075/1/683x911/speed-motion-2025.webp"},
  {slug:"nox-at10-genius-12k",name:"AT10 Genius 12K",brand:"NOX",level:"advanced",shape:"teardrop",price:178,score:91,power:86,control:88,touch:84,badge:null,tags:["Control","Teardrop","Carbon 12K"],img:""},
  {slug:"bullpadel-vertex-05",name:"Vertex 05",brand:"Bullpadel",level:"advanced",shape:"diamond",price:259,score:90,power:90,control:82,touch:76,badge:null,tags:["Power","Diamond","Advanced"],img:""},
  {slug:"babolat-technical-viper-3",name:"Technical Viper 3.0",brand:"Babolat",level:"advanced",shape:"diamond",price:299,score:89,power:93,control:74,touch:70,badge:null,tags:["Max Power","Diamond","Carbon"],img:""},
  {slug:"adidas-metalbone-2026",name:"Metalbone 2026",brand:"Adidas",level:"advanced",shape:"diamond",price:320,score:92,power:91,control:83,touch:78,badge:null,tags:["Power","Diamond","16K Carbon"],img:""},
  {slug:"oxdog-hyper-pro-2",name:"Hyper Pro 2.0",brand:"Oxdog",level:"intermediate",shape:"teardrop",price:260,score:87,power:82,control:86,touch:83,badge:null,tags:["Balanced","Teardrop","HES-Carbon"],img:""}
];

var bestPicks = [
  {label:"Best Overall",slug:"bullpadel-hack-03-hybrid",name:"Hack 03 Hybrid",brand:"Bullpadel",score:94},
  {label:"Best for Beginners",slug:"head-speed-motion",name:"Speed Motion",brand:"Head",score:85},
  {label:"Best for Control",slug:"nox-at10-genius-12k",name:"AT10 Genius 12K",brand:"NOX",score:91},
  {label:"Best for Power",slug:"babolat-technical-viper-3",name:"Technical Viper 3.0",brand:"Babolat",score:89},
  {label:"Premium Pick",slug:"adidas-metalbone-2026",name:"Metalbone 2026",brand:"Adidas",score:92},
  {label:"Best Mid-Range",slug:"oxdog-hyper-pro-2",name:"Hyper Pro 2.0",brand:"Oxdog",score:87}
];

document.getElementById('bestGrid').innerHTML = bestPicks.map(function(p) {
  return '<a class="best-card" href="review.html?racket=' + p.slug + '">' +
    '<div class="best-label">' + p.label + '</div>' +
    '<div class="best-name">' + p.name + '</div>' +
    '<div class="best-brand">' + p.brand + '</div>' +
    '<div class="best-score">' + p.score + '</div>' +
  '</a>';
}).join('');

function svgIcon() {
  return '<svg class="img-fallback" width="65" height="110" viewBox="0 0 80 130" fill="none">' +
    '<ellipse cx="40" cy="52" rx="36" ry="46" stroke="#c8f135" stroke-width="3"/>' +
    '<line x1="40" y1="6" x2="40" y2="98" stroke="#c8f135" stroke-width="1.5"/>' +
    '<line x1="4" y1="40" x2="76" y2="40" stroke="#c8f135" stroke-width="1.5"/>' +
    '<line x1="8" y1="22" x2="72" y2="22" stroke="#c8f135" stroke-width="1"/>' +
    '<line x1="8" y1="58" x2="72" y2="58" stroke="#c8f135" stroke-width="1"/>' +
    '<line x1="17" y1="10" x2="17" y2="94" stroke="#c8f135" stroke-width="1"/>' +
    '<line x1="63" y1="10" x2="63" y2="94" stroke="#c8f135" stroke-width="1"/>' +
    '<rect x="33" y="98" width="14" height="30" rx="5" fill="#c8f135"/></svg>';
}

function renderCard(r) {
  var badge = r.badge ? '<div class="card-badge ' + r.badge + '">' + r.badgeText + '</div>' : '';
  var tags  = r.tags.map(function(t){ return '<span class="tag">' + t + '</span>'; }).join('');
  var orig  = r.origPrice ? '<span class="orig">£' + r.origPrice + '</span>' : '';
  var imgHtml = r.img ? '<img src="' + r.img + '" alt="' + r.name + ' padel racket" loading="lazy" onerror="this.style.display=\'none\'">' : svgIcon();
  return '<a class="card" href="review.html?racket=' + r.slug + '">' +
    '<div class="card-img">' + imgHtml + badge + '</div>' +
    '<div class="card-body">' +
      '<div class="card-top"><div><div class="card-title">' + r.name + '</div><div class="card-brand">' + r.brand + '</div></div><div class="score">' + r.score + '</div></div>' +
      '<div class="tags">' + tags + '</div>' +
      '<div class="stat-bars">' +
        '<div class="stat-row"><span class="stat-label">Power</span><div class="stat-track"><div class="stat-fill" style="width:' + r.power + '%"></div></div><span class="stat-val">' + r.power + '</span></div>' +
        '<div class="stat-row"><span class="stat-label">Control</span><div class="stat-track"><div class="stat-fill" style="width:' + r.control + '%"></div></div><span class="stat-val">' + r.control + '</span></div>' +
        '<div class="stat-row"><span class="stat-label">Touch</span><div class="stat-track"><div class="stat-fill" style="width:' + r.touch + '%"></div></div><span class="stat-val">' + r.touch + '</span></div>' +
      '</div>' +
      '<div class="card-bottom"><div class="price">£' + r.price + orig + '</div><span class="btn">View Review →</span></div>' +
    '</div>' +
  '</a>';
}

function getFilters() {
  return {
    level: document.getElementById('filterLevel').value,
    shape: document.getElementById('filterShape').value,
    price: parseInt(document.getElementById('filterPrice').value),
    sort:  document.getElementById('sortBy').value
  };
}

function applyFilters() {
  var f = getFilters();
  var d = rackets.filter(function(r) {
    return (f.level === 'all' || r.level === f.level) &&
           (f.shape === 'all' || r.shape === f.shape) &&
           r.price <= f.price;
  });
  if (f.sort === 'score')           d.sort(function(a,b){ return b.score   - a.score;   });
  else if (f.sort === 'price_asc')  d.sort(function(a,b){ return a.price   - b.price;   });
  else if (f.sort === 'price_desc') d.sort(function(a,b){ return b.price   - a.price;   });
  else if (f.sort === 'power')      d.sort(function(a,b){ return b.power   - a.power;   });
  else if (f.sort === 'control')    d.sort(function(a,b){ return b.control - a.control; });
  document.getElementById('racketGrid').innerHTML = d.length
    ? d.map(renderCard).join('')
    : '<div class="no-results">No rackets match your filters. Try adjusting above.</div>';
  document.getElementById('countLabel').innerHTML =
    '<strong>' + d.length + '</strong> racket' + (d.length !== 1 ? 's' : '') + ' found';
}

['filterLevel','filterShape','filterPrice','sortBy'].forEach(function(id) {
  document.getElementById(id).addEventListener('change', applyFilters);
});
applyFilters();
</script>
</body>
</html>
